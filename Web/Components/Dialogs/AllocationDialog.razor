@using Application.DTO
@using Application.Interface
@using Application.Services.AllocationService
@using Domain.Entities
@using Microsoft.AspNetCore.Components.Forms

@inject IAllocationService AllocationService
@inject ISnackbar Snackbar

<MudDialog Style="max-width: 600px; width: 100%; border-radius: 12px;">
    <TitleContent>
        <div class="d-flex align-center justify-space-between width-100">
            <MudText Typo="Typo.h6" Class="font-weight-bold">New Allocation</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form" Class="d-flex flex-column gap-4 pt-2">
            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Booking Id</MudText>
                <MudNumericField T="int" Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  @bind-Value="Model.BookingId"
                                  HideSpinButtons="true" />
            </div>

            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Room Id</MudText>
                <MudNumericField T="int" Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  @bind-Value="Model.RoomId"
                                  HideSpinButtons="true" />
            </div>

            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Check In Date</MudText>
                <MudDatePicker @bind-Date="CheckInDateBinding" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </div>

            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Expected Check Out Date</MudText>
                <MudDatePicker @bind-Date="ExpectedCheckOutDateBinding" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </div>

            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Actual Check Out Date</MudText>
                <MudDatePicker @bind-Date="ActualCheckOutDateBinding" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </div>

            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Status</MudText>
                <MudSelect T="string" @bind-Value="Model.Status" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                    <MudSelectItem Value="@("Confirmed")">Confirmed</MudSelectItem>
                </MudSelect>
            </div>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <div class="d-flex justify-end gap-3 width-100 pa-4 pt-0">
            <MudButton Variant="Variant.Outlined"
                       OnClick="Cancel"
                       Style="text-transform: none; border-radius: 8px; border: 1px solid #E5E7EB; color: #1F2937;"
                       Class="px-5 font-weight-bold">
                Cancel
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="Submit"
                       Style="text-transform: none; border-radius: 8px; background-color: #e3a387;"
                       Class="px-5 font-weight-bold">
                Create Allocation
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public CreateAllocationDTO Model { get; set; } = new() { Status = "Pending" };

    private MudForm _form = default!;

    private DateTime? CheckInDateBinding
    {
        get => Model.CheckInDate == default ? null : Model.CheckInDate;
        set => Model.CheckInDate = value ?? default;
    }

    private DateTime? ExpectedCheckOutDateBinding
    {
        get => Model.ExpectedCheckOutDate == default ? null : Model.ExpectedCheckOutDate;
        set => Model.ExpectedCheckOutDate = value ?? default;
    }

    private DateTime? ActualCheckOutDateBinding
    {
        get => Model.ActualCheckOutDate == default ? null : Model.ActualCheckOutDate;
        set => Model.ActualCheckOutDate = value ?? default;
    }

    private async Task Submit()
    {
        try
        {
            if (Model.BookingId <= 0)
            {
                Snackbar.Add("Please provide a valid Booking Id.", Severity.Warning);
                return;
            }

            if (Model.RoomId <= 0)
            {
                Snackbar.Add("Please provide a valid Room Id.", Severity.Warning);
                return;
            }

            if (Model.CheckInDate == default)
            {
                Snackbar.Add("Please select a check-in date.", Severity.Warning);
                return;
            }

            if (Model.ExpectedCheckOutDate == default)
            {
                Snackbar.Add("Please select an expected check-out date.", Severity.Warning);
                return;
            }

            if (Model.ActualCheckOutDate == default)
            {
                Snackbar.Add("Please select an actual check-out date.", Severity.Warning);
                return;
            }

            if (Model.ExpectedCheckOutDate <= Model.CheckInDate)
            {
                Snackbar.Add("Expected check-out date must be after check-in date.", Severity.Warning);
                return;
            }

            if (Model.ActualCheckOutDate < Model.CheckInDate)
            {
                Snackbar.Add("Actual check-out date must be after or equal to check-in date.", Severity.Warning);
                return;
            }

            await AllocationService.CreateAllocationAsync(Model);
            Snackbar.Add("Allocation created successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating allocation: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}

