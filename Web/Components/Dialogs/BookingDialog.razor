@using Application.DTO
@using Application.Interface
@using Application.Services.BookingService
@using Application.Services.GuestService
@using Application.Services.RoomCategoryService
@using Application.Services.RoomService
@using Domain.Entities
@using Microsoft.EntityFrameworkCore
@inject IRoomService RoomService
@inject IBookingService BookingService
@inject IGuestService GuestService
@inject IRoomCategoryService RoomCategoryService
@inject ISnackbar Snackbar


<MudDialog Style="max-width: 500px; width: 100%; border-radius: 12px;">
    <TitleContent>
        <div class="d-flex align-center justify-space-between width-100">
            <MudText Typo="Typo.h6" Class="font-weight-bold">New Booking</MudText>
            @* <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Medium" OnClick="Cancel" /> *@
        </div>
    </TitleContent>
    
    <DialogContent>
        <MudForm @ref="_form" Class="d-flex flex-column gap-4 pt-2">
            
            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Room</MudText>
                <MudSelect T="int" Value="Model.RoomId" ValueChanged="OnRoomChanged" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Placeholder="Select Room">
                    @foreach (var room in _rooms)
                    {
                        <MudSelectItem Value="@room.Id">@room.RoomCode</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Guest</MudText>
                <MudSelect T="int" @bind-Value="Model.GuestId" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Placeholder="Guest">
                    @foreach (var guest in _guests)
                    {
                        <MudSelectItem Value="@guest.Id">@guest.FullName</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Check In Date</MudText>
                <MudDatePicker @bind-Date="CheckInDateBinding" 
                              Variant="Variant.Outlined" 
                              Margin="Margin.Dense" />
            </div>
            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Check Out Date</MudText>
                <MudDatePicker @bind-Date="CheckOutDateBinding" 
                              Variant="Variant.Outlined" 
                              Margin="Margin.Dense" />
            </div>
            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Amount Due</MudText>
                <MudNumericField Variant="Variant.Outlined" 
                                 Margin="Margin.Dense" @bind-Value="Model.AmountDue" 
                                 ReadOnly="true"
                                 HideSpinButtons="true" Adornment="Adornment.Start" AdornmentText="Frw" />
            </div>
            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Booking Amount</MudText>
                <MudNumericField Variant="Variant.Outlined" 
                                 Margin="Margin.Dense" @bind-Value="Model.BookingAmount" 
                                 ReadOnly="true"
                                 HideSpinButtons="true" Adornment="Adornment.Start" AdornmentText="Frw" />
            </div>

            <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Status</MudText>
                <MudSelect T="string" @bind-Value="Model.Status" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                    <MudSelectItem Value="@("Confirmed")">Confirmed</MudSelectItem>
                    @* <MudSelectItem Value="@("Maintenance")">Maintenance</MudSelectItem> *@
                </MudSelect>
            </div>

            @* <div>
                <MudText Typo="Typo.body2" Class="text-secondary mb-1 font-weight-medium">Room Category</MudText>
                <MudSelect T="int" @bind-Value="Model.RoomCategoryId" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Placeholder="Select Category">
                    @foreach (var category in _categories)
                    {
                        <MudSelectItem Value="@category.Id">@category.Name (@category.PricePerDay.ToString("C") / Day)</MudSelectItem>
                    }
                </MudSelect>
            </div> *@

        </MudForm>
    </DialogContent>
    
    <DialogActions>
        <div class="d-flex justify-end gap-3 width-100 pa-4 pt-0">
            <MudButton Variant="Variant.Outlined" 
                       OnClick="Cancel" 
                       Style="text-transform: none; border-radius: 8px; border: 1px solid #E5E7EB; color: #1F2937;" 
                       Class="px-5 font-weight-bold">
                Cancel
            </MudButton>
            
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       OnClick="Submit" 
                       Style="text-transform: none; border-radius: 8px; background-color: #e3a387;" 
                       Class="px-5 font-weight-bold">
                Create Booking
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public CreateBookingDTO Model { get; set; } = new() { Status = "Pending"};

    private MudForm _form = default!;
    private List<Room> _rooms = new();
    private List<Guest> _guests = new();
    private decimal _pricePerDay = 0;

    protected override async Task OnInitializedAsync()
    {
        _rooms = await RoomService.GetAllAsync();
        if (_rooms.Any())
        {
            if (Model.RoomId == 0)
            {
                Model.RoomId = _rooms.First().Id;
            }
            
            var selectedRoom = _rooms.FirstOrDefault(r => r.Id == Model.RoomId);
            if (selectedRoom?.RoomCategory != null)
            {
                _pricePerDay = selectedRoom.RoomCategory.PricePerDay;
            }
        }

        _guests = await GuestService.GetAllAsync();
        if (_guests.Any() && Model.GuestId == 0)
        {
            Model.GuestId = _guests.First().Id;
        }

        CalculateAmounts();
    }

    private async Task Submit()
    {
        try
        {
            if (Model.RoomId <= 0)
            {
                Snackbar.Add("Please select a room.", Severity.Warning);
                return;
            }

            if (Model.GuestId <= 0)
            {
                Snackbar.Add("Please select a guest.", Severity.Warning);
                return;
            }

            if (Model.CheckInDate == default)
            {
                Snackbar.Add("Please select check-in date.", Severity.Warning);
                return;
            }

            if (Model.CheckOutDate == default)
            {
                Snackbar.Add("Please select check-out date.", Severity.Warning);
                return;
            }

            if (Model.CheckOutDate <= Model.CheckInDate)
            {
                Snackbar.Add("Check-out date must be after check-in date.", Severity.Warning);
                return;
            }

            await BookingService.CreateBookingAsync(Model);
            Snackbar.Add("Booking created successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving booking: {ex.Message}", Severity.Error);
        }
    }

    private Task OnRoomChanged(int roomId)
    {
        Model.RoomId = roomId;
        var selectedRoom = _rooms.FirstOrDefault(r => r.Id == roomId);
        if (selectedRoom?.RoomCategory != null)
        {
            _pricePerDay = selectedRoom.RoomCategory.PricePerDay;
        }
        else
        {
            _pricePerDay = 0;
        }
        CalculateAmounts();
        return Task.CompletedTask;
    }

    private DateTime? CheckInDateBinding
    {
        get => Model.CheckInDate == default ? null : Model.CheckInDate.ToDateTime(TimeOnly.MinValue);
        set
        {
            if (value.HasValue)
            {
                Model.CheckInDate = DateOnly.FromDateTime(value.Value);
            }
            else
            {
                Model.CheckInDate = default;
            }
            CalculateAmounts();
        }
    }

    private DateTime? CheckOutDateBinding
    {
        get => Model.CheckOutDate == default ? null : Model.CheckOutDate.ToDateTime(TimeOnly.MinValue);
        set
        {
            if (value.HasValue)
            {
                Model.CheckOutDate = DateOnly.FromDateTime(value.Value);
            }
            else
            {
                Model.CheckOutDate = default;
            }
            CalculateAmounts();
        }
    }

    private void CalculateAmounts()
    {
        if (Model.CheckInDate == default || Model.CheckOutDate == default || _pricePerDay == 0)
        {
            Model.AmountDue = 0;
            Model.BookingAmount = 0;
            return;
        }

        // Duration = CheckOutDate - CheckInDate
        int duration = (Model.CheckOutDate.ToDateTime(TimeOnly.MinValue) - Model.CheckInDate.ToDateTime(TimeOnly.MinValue)).Days;

        if (duration < 0)
        {
            duration = 0;
        }

        // AmountDue = PricePerDay * Duration
        Model.AmountDue = _pricePerDay * duration;

        // BookingAmount = (AmountDue * 40) / 100
        Model.BookingAmount = (Model.AmountDue * 40) / 100;
    }

    private void Cancel() => MudDialog.Cancel();
}
